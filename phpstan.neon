includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - src
    ignoreErrors:
        -
            identifier: arguments.count
            path: src/Support/RedisStore.php
        -
            identifier: argument.type
            path: src/Support/RedisStore.php
        -
            identifier: trait.unused
            path: src/Traits/*
